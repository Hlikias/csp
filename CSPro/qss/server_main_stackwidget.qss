QLabel {
    background-color: #f5f5f5;
    border: 1px solid #dddddd;
    border-radius: 3px;
    padding: 4px 8px;
}
*/

QProgressBar { 
    background-color: lightgray; 
} 
QProgressBar::chunk { 
    background-color: green; 
}